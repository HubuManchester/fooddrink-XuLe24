<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodieApp.ViewModels"
             x:Class="FoodieApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}"
             SemanticProperties.Description="Settings page for accessibility and display preferences.">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Settings" Style="{StaticResource HeadlineLabel}"
                   SemanticProperties.HeadingLevel="Level1" />
            <Frame Style="{StaticResource CardFrame}" BackgroundColor="{StaticResource PrimaryLight}">
                <Label Text="These settings improve accessibility and are applied immediately."
                       Style="{StaticResource BodyLabel}" TextColor="{StaticResource PrimaryDark}" />
            </Frame>

            <Label Text="Display" Style="{StaticResource TitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />
            <Frame Style="{StaticResource CardFrame}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Dark Mode" Style="{StaticResource BodyLabel}" FontAttributes="Bold" />
                        <Label Text="Switch between light and dark theme (WCAG 1.4.3)"
                               Style="{StaticResource CaptionLabel}" />
                    </VerticalStackLayout>
                    <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}"
                            OnColor="{StaticResource Primary}"
                            SemanticProperties.Hint="Toggle between light and dark theme"
                            AutomationId="DarkModeSwitch" />
                </Grid>
            </Frame>

            <Label Text="Accessibility" Style="{StaticResource TitleLabel}"
                   SemanticProperties.HeadingLevel="Level2" />
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Font Size" Style="{StaticResource BodyLabel}" FontAttributes="Bold" />
                    <Label Text="Choose a text size to improve readability (WCAG 1.4.4)"
                           Style="{StaticResource CaptionLabel}" />
                    <Label Text="Sample text - this is how recipes will look."
                           FontSize="{Binding PreviewFontSize}"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource TextPrimaryDark}}"
                           SemanticProperties.Description="Font size preview" />
                    <Picker Title="Select font size"
                            ItemsSource="{Binding FontSizeOptions}"
                            SelectedItem="{Binding SelectedFontSizeOption}"
                            SemanticProperties.Hint="Choose Normal, Large, or Extra Large font size"
                            AutomationId="FontSizePicker" />
                    <Label Text="{Binding SelectedFontSizeOption, StringFormat='Current size: {0}'}"
                           Style="{StaticResource CaptionLabel}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Frame>

            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Screen Reader Support" Style="{StaticResource BodyLabel}" FontAttributes="Bold" />
                    <Label Text="All images and buttons include semantic descriptions for TalkBack (Android) and Narrator (Windows). (WCAG 1.1.1, 4.1.2)"
                           Style="{StaticResource CaptionLabel}" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Reset to Defaults" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ResetDefaultsCommand}"
                    SemanticProperties.Hint="Reset theme and font size to default values"
                    Margin="0,8,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
