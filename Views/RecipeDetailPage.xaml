<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodieApp.ViewModels"
             x:Class="FoodieApp.Views.RecipeDetailPage"
             x:DataType="vm:RecipeDetailViewModel"
             Title="{Binding Title}"
             SemanticProperties.Description="Recipe detail page with ingredients and cooking steps.">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Help" Clicked="OnHelpClicked"
                     SemanticProperties.Hint="Open the help page" />
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Margin="0,40,0,0" HorizontalOptions="Center"
                               SemanticProperties.Description="Loading recipe details" />
            <VerticalStackLayout IsVisible="{Binding IsNotBusy}" Spacing="0">
                <Image Source="{Binding Recipe.ImageUrl}" Aspect="AspectFill" HeightRequest="240"
                       SemanticProperties.Description="{Binding Recipe.Name, StringFormat='Photo of {0}'}" />
                <VerticalStackLayout Padding="20,16" Spacing="20">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding Recipe.Name}" Style="{StaticResource HeadlineLabel}"
                               SemanticProperties.HeadingLevel="Level1" />
                        <Label Text="{Binding Recipe.Summary}" Style="{StaticResource CaptionLabel}" />
                        <HorizontalStackLayout Spacing="8">
                            <Frame Padding="8,4" CornerRadius="8" HasShadow="False"
                                   BackgroundColor="{StaticResource PrimaryLight}">
                                <Label Text="{Binding Recipe.Category}" TextColor="White"
                                       FontSize="{DynamicResource CaptionFontSize}" FontAttributes="Bold" />
                            </Frame>
                            <Frame Padding="8,4" CornerRadius="8" HasShadow="False"
                                   BackgroundColor="{StaticResource Border}">
                                <Label Text="{Binding Recipe.Area}"
                                       FontSize="{DynamicResource CaptionFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </Frame>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Ingredients" Style="{StaticResource TitleLabel}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <CollectionView ItemsSource="{Binding Recipe.Ingredients}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <HorizontalStackLayout Spacing="10" Padding="0,4">
                                        <Ellipse Fill="{StaticResource Primary}"
                                                 WidthRequest="8" HeightRequest="8" VerticalOptions="Center" />
                                        <Label Text="{Binding .}" Style="{StaticResource BodyLabel}" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,8,0,0">
                            <Button Grid.Column="0" Text="Read Aloud"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ReadAloudCommand}"
                                    IsEnabled="{Binding IsNotBusy}"
                                    SemanticProperties.Hint="Read the recipe name and ingredients aloud" />
                            <Button Grid.Column="1" Text="Stop"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding StopReadingCommand}"
                                    IsVisible="{Binding IsSpeaking}"
                                    SemanticProperties.Hint="Stop reading aloud" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12">
                        <Label Text="Cooking Steps" Style="{StaticResource TitleLabel}"
                               SemanticProperties.HeadingLevel="Level2" />
                        <Label Text="{Binding StepProgress}" Style="{StaticResource CaptionLabel}"
                               SemanticProperties.Description="{Binding StepProgress}" />
                        <Frame Style="{StaticResource CardFrame}">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="{Binding CurrentStep}" Style="{StaticResource BodyLabel}"
                                       SemanticProperties.Description="{Binding CurrentStep}" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="Previous"
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding PreviousStepCommand}"
                                            IsEnabled="{Binding CanGoBack}"
                                            SemanticProperties.Hint="Go to the previous cooking step" />
                                    <Button Grid.Column="1" Text="Next"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding NextStepCommand}"
                                            IsEnabled="{Binding CanGoForward}"
                                            SemanticProperties.Hint="Go to the next cooking step" />
                                </Grid>
                            </VerticalStackLayout>
                        </Frame>
                        <Button Text="Favourite"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding ToggleFavouriteCommand}"
                                SemanticProperties.Hint="Save or remove this recipe from favourites" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
