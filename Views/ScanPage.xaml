<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodieApp.ViewModels"
             x:Class="FoodieApp.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             Title="{Binding Title}"
             SemanticProperties.Description="Scan page. Use your camera to photograph a food item.">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Scan Food" Style="{StaticResource HeadlineLabel}"
                   SemanticProperties.HeadingLevel="Level1" />
            <Label Text="Take a photo of any food item to identify it." Style="{StaticResource BodyLabel}" />
            <Frame Style="{StaticResource CardFrame}" Padding="0" HeightRequest="280">
                <Grid>
                    <Label Text="No photo captured yet" Style="{StaticResource CaptionLabel}"
                           HorizontalTextAlignment="Center" VerticalOptions="Center"
                           IsVisible="{Binding HasImage, Converter={StaticResource InverseBoolConverter}}" />
                    <Image Source="{Binding CapturedImage}" Aspect="AspectFill"
                           IsVisible="{Binding HasImage}"
                           SemanticProperties.Description="Captured food photo" />
                </Grid>
            </Frame>
            <Label Text="{Binding StatusMessage}" Style="{StaticResource BodyLabel}"
                   HorizontalTextAlignment="Center"
                   SemanticProperties.Description="{Binding StatusMessage}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Text="Take Photo" Style="{StaticResource PrimaryButton}"
                    Command="{Binding CapturePhotoCommand}" IsEnabled="{Binding IsNotBusy}"
                    SemanticProperties.Hint="Open the camera to photograph your food item" />
            <Button Text="Choose from Gallery" Style="{StaticResource SecondaryButton}"
                    Command="{Binding PickPhotoCommand}" IsEnabled="{Binding IsNotBusy}"
                    SemanticProperties.Hint="Select an existing photo from your gallery" />
            <Button Text="Clear Photo" Style="{StaticResource SecondaryButton}"
                    Command="{Binding ClearPhotoCommand}" IsVisible="{Binding HasImage}"
                    SemanticProperties.Hint="Remove the current photo and start again" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>